{
  "manifest_version": 3,
  "name": "Copilot Doctor",
  "description": "Check orders from Copilot against UiPath Orchestrator jobs",
  "version": "0.4.0",
  "author": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Copilot Doctor"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://copilot.apexmedical.ai/*",
        "https://pre-prod.apexmedicalai.com/*",
        "https://pre-prod-copilot.apexmedicalai.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": [
    "https://copilot.apexmedical.ai/*",
    "https://pre-prod.apexmedicalai.com/*",
    "https://pre-prod-copilot.apexmedicalai.com/*",
    "https://cloud.uipath.com/*"
  ]
}
